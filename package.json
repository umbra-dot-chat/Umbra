{
  "name": "umbra-monorepo",
  "version": "1.9.0",
  "private": true,
  "description": "Umbra — P2P Encrypted Messaging App (monorepo)",
  "scripts": {
    "postinstall": "git submodule update --init --recursive",
    "setup": "git submodule update --init --recursive && cd packages/umbra-app && npm install",
    "build:wasm": "cd packages/umbra-wasm && npm run build",
    "build:web": "cd packages/umbra-app && npm run build:web",
    "build:desktop": "cd packages/umbra-app && npm run build:desktop",
    "build:mobile": "cd packages/umbra-app && npm run build:mobile",
    "web": "cd packages/umbra-app && npm run web",
    "start": "cd packages/umbra-app && npm run start",
    "test": "cd packages/umbra-app && npm test",
    "test:e2e": "cd packages/umbra-app && npm run test:e2e",
    "deploy": "cd packages/umbra-app && npm run deploy",
    "deploy:relay": "cd packages/umbra-relay && cargo build --release"
  }
}
